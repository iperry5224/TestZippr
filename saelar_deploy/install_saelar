#!/usr/bin/env bash
#===============================================================================
#  SAELAR - One-command install (Linux)
#  Usage: ./install_saelar   or add to PATH and run: install_saelar
#  Expects SAELAR-distro-*.zip in same dir, or run from an extracted distro dir.
#===============================================================================
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PORT="${SAELAR_PORT:-8484}"

echo ""
echo -e "${CYAN}  SAELAR - One-command install (Linux)${NC}"
echo ""

# Resolve app dir: from zip or existing extracted dir
APP_DIR=""
ZIP_FILE=""

for d in "$SCRIPT_DIR" . ; do
  ZIP_FILE=$(ls -t "$d"/SAELAR-distro-*.zip 2>/dev/null | head -1)
  if [ -n "$ZIP_FILE" ] && [ -f "$ZIP_FILE" ]; then
    EXTRACT_TO="$(dirname "$ZIP_FILE")/SAELAR"
    # Remove previous install at target for a fresh install
    if [ -d "$EXTRACT_TO" ]; then
      echo -e "${YELLOW}[1/4]${NC} Removing previous install at $EXTRACT_TO for clean install..."
      rm -rf "$EXTRACT_TO"
    fi
    echo -e "${GREEN}[1/4]${NC} Found $(basename "$ZIP_FILE"), extracting to $EXTRACT_TO ..."
    mkdir -p "$EXTRACT_TO"
    unzip -o -q "$ZIP_FILE" -d "$EXTRACT_TO"
    APP_DIR="$EXTRACT_TO"
    break
  fi
done

if [ -z "$APP_DIR" ]; then
  # Already in an extracted dir?
  if [ -f "$SCRIPT_DIR/nist_setup.py" ] && [ -f "$SCRIPT_DIR/requirements.txt" ]; then
    APP_DIR="$SCRIPT_DIR"
    echo -e "${GREEN}[1/4]${NC} Using current directory (already extracted)"
  elif [ -f "./nist_setup.py" ] && [ -f "./requirements.txt" ]; then
    APP_DIR="$(pwd)"
    echo -e "${GREEN}[1/4]${NC} Using current directory (already extracted)"
  else
    echo -e "${RED}No SAELAR distro found.${NC}"
    echo "  Put SAELAR-distro-*.zip in the same folder as this script, then run: ./install_saelar"
    exit 1
  fi
fi

# Optional: remove previous system install at /opt/apps (common on EC2)
if [ -f "/opt/apps/nist_setup.py" ]; then
  echo -e "${YELLOW}  Previous SAELAR install found at /opt/apps.${NC}"
  read -p "  Remove it for a clean install? (y/N): " -n 1 -r
  echo
  if [[ $REPLY =~ ^[Yy]$ ]]; then
    echo "  Removing /opt/apps..."
    sudo rm -rf /opt/apps
    echo -e "  ${GREEN}Removed.${NC}"
  fi
fi

# Clean caches and leftover state for fresh run (in-place install)
if [ -d "$APP_DIR" ]; then
  rm -rf "$APP_DIR/__pycache__" "$APP_DIR/.streamlit" 2>/dev/null || true
  find "$APP_DIR" -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
fi

cd "$APP_DIR"
echo -e "${GREEN}[2/4]${NC} App dir: $APP_DIR"

# Python
PYTHON=""
for cmd in python3 python; do
  if command -v "$cmd" &>/dev/null; then
    PYTHON="$cmd"
    break
  fi
done
if [ -z "$PYTHON" ]; then
  echo -e "${RED}Python not found. Install python3.${NC}"
  exit 1
fi
echo -e "${GREEN}[3/4]${NC} Using: $PYTHON"

# Dependencies
echo "    Installing dependencies..."
$PYTHON -m pip install --upgrade pip -q
$PYTHON -m pip install -r requirements.txt -q
echo -e "    ${GREEN}Done.${NC}"

# Start script
cat > start_saelar.sh << EOF
#!/usr/bin/env bash
cd "$APP_DIR"
PORT="\${SAELAR_PORT:-$PORT}"
echo ""
echo "  SAELAR - NIST 800-53"
echo "  http://localhost:\$PORT"
echo ""
exec $PYTHON -m streamlit run nist_setup.py --server.port "\$PORT" --server.address 0.0.0.0 --server.headless true
EOF
chmod +x start_saelar.sh
echo -e "${GREEN}[4/4]${NC} Created start_saelar.sh"

echo ""
echo -e "${GREEN}  Install complete.${NC}"
echo "  To start SAELAR:"
echo "    cd $APP_DIR"
echo "    ./start_saelar.sh"
echo ""
echo "  Or run from anywhere (add to PATH):  $APP_DIR/start_saelar.sh"
echo ""
